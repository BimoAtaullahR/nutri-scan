{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nutriscan.local/contracts/ai-inference/scan-inference.schema.json",
  "title": "ScanInferencePayload",
  "description": "Contract for the Backend API to AI/ML Inference boundary.",
  "type": "object",
  "required": [
    "modelVersion",
    "foodCategory",
    "alternatives",
    "coarsePortion",
    "estimatedEnergyRange",
    "isLowConfidence",
    "confidenceThreshold"
  ],
  "properties": {
    "modelVersion": {
      "type": "string"
    },
    "foodCategory": {
      "type": "object",
      "required": ["slug", "confidenceScore"],
      "properties": {
        "slug": {
          "type": "string"
        },
        "confidenceScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "alternatives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug", "confidenceScore"],
        "properties": {
          "slug": {
            "type": "string"
          },
          "confidenceScore": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "coarsePortion": {
      "type": "string",
      "enum": ["small", "medium", "large"]
    },
    "estimatedEnergyRange": {
      "type": ["object", "null"],
      "properties": {
        "minKcal": {
          "type": "integer",
          "minimum": 0
        },
        "maxKcal": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "isLowConfidence": {
      "type": "boolean"
    },
    "confidenceThreshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
