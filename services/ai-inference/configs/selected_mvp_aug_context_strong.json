{
  "model_name": "convnext_tiny.fb_in1k",
  "pretrained": true,
  "num_classes": 8,
  "class_config": "configs/mvp_food_categories.json",
  "image_size": 256,
  "batch_size": 8,
  "epochs": 20,
  "learning_rate": 0.0001,
